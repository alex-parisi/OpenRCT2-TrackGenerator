# One tile-length track segment, authored straight along +Z (z in [0, 3.3]).
# x is across-track, y is up. The generator deforms this along each section curve.
# Faces are wound CCW as seen from above so the +Y normal is consistent.
mtllib track_tile.mtl
o track_tile

# deck (y = 0)
v -0.60 0.00 0.00
v 0.60 0.00 0.00
v 0.60 0.00 3.30
v -0.60 0.00 3.30
# left rail top (y = 0.15)
v -0.55 0.15 0.00
v -0.45 0.15 0.00
v -0.45 0.15 3.30
v -0.55 0.15 3.30
# right rail top (y = 0.15)
v 0.45 0.15 0.00
v 0.55 0.15 0.00
v 0.55 0.15 3.30
v 0.45 0.15 3.30
# cross-tie 1 (z 0.7..0.9, y = 0.05)
v -0.60 0.05 0.70
v 0.60 0.05 0.70
v 0.60 0.05 0.90
v -0.60 0.05 0.90
# cross-tie 2 (z 2.4..2.6, y = 0.05)
v -0.60 0.05 2.40
v 0.60 0.05 2.40
v 0.60 0.05 2.60
v -0.60 0.05 2.60

vn 0.0 1.0 0.0

usemtl Remap1
f 1//1 4//1 3//1
f 1//1 3//1 2//1
f 5//1 8//1 7//1
f 5//1 7//1 6//1
f 9//1 12//1 11//1
f 9//1 11//1 10//1
f 13//1 16//1 15//1
f 13//1 15//1 14//1
f 17//1 20//1 19//1
f 17//1 19//1 18//1
