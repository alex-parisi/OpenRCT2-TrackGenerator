# One tile-length track segment in maketrack's mesh convention: +X is along-track
# (x in [0, 3.3]), Z is across-track (centred), Y is up. The loader applies
# rotate_y(-90deg) so the deform receives it as +Z along-track. Faces wound CCW from
# above for a consistent +Y normal.
mtllib track_tile.mtl
o track_tile

# deck (y = 0)
v 0.00 0.00 0.60
v 0.00 0.00 -0.60
v 3.30 0.00 -0.60
v 3.30 0.00 0.60
# left rail top (y = 0.15)
v 0.00 0.15 0.55
v 0.00 0.15 0.45
v 3.30 0.15 0.45
v 3.30 0.15 0.55
# right rail top (y = 0.15)
v 0.00 0.15 -0.45
v 0.00 0.15 -0.55
v 3.30 0.15 -0.55
v 3.30 0.15 -0.45
# cross-tie 1 (x 0.7..0.9, y = 0.05)
v 0.70 0.05 0.60
v 0.70 0.05 -0.60
v 0.90 0.05 -0.60
v 0.90 0.05 0.60
# cross-tie 2 (x 2.4..2.6, y = 0.05)
v 2.40 0.05 0.60
v 2.40 0.05 -0.60
v 2.60 0.05 -0.60
v 2.60 0.05 0.60

vn 0.0 1.0 0.0

usemtl Remap1
f 1//1 4//1 3//1
f 1//1 3//1 2//1
f 5//1 8//1 7//1
f 5//1 7//1 6//1
f 9//1 12//1 11//1
f 9//1 11//1 10//1
f 13//1 16//1 15//1
f 13//1 15//1 14//1
f 17//1 20//1 19//1
f 17//1 19//1 18//1
